<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Keylogger99.MainWindow"
        Title="Keylogger99" 
        Height="450" Width="600"
        Background="#1e1e1e"> <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        
        <TextBlock Name="StatusLabel" Grid.Row="0" 
                   Text="Status: Ready" 
                   Foreground="White" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" CornerRadius="5" Background="#2d2d2d">
            <ScrollViewer>
                <TextBlock Name="KeyLogDisplay" 
                           Foreground="#00ff00" 
                           FontFamily="Courier New" 
                           TextWrapping="Wrap" 
                           Padding="10"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
            <Button Content="Stop Recording" Click="OnStopClick" Background="#e74c3c" Foreground="White" Padding="15,7"/>
            <Button Content="Clear" Click="OnClearClick" Background="#3498db" Foreground="White" Padding="15,7"/>
        </StackPanel>
        
    </Grid>
</Window>
