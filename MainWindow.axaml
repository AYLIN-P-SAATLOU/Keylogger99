<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Keylogger99.MainWindow"
        Title="Keylogger99 - Activity Monitor"
        Width="500" Height="400">
    
    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="5">
            <TextBlock Text="Keylogger99" FontSize="24" FontWeight="Bold" Foreground="#3498db"/>
            <TextBlock Name="StatusLabel" Text="Status: Initializing..." FontStyle="Italic"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,15" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="5">
            <ScrollViewer>
                <TextBlock Name="KeyLogDisplay" 
                           TextWrapping="Wrap" 
                           Padding="10" 
                           FontSize="14" 
                           FontFamily="Courier New"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Clear Logs" Click="OnClearClick" Background="#e74c3c" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
